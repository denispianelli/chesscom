{
  "name": "@dpianelli/chesscom",
  "version": "0.2.0",
  "description": "Unofficial TypeScript SDK for the Chess.com Published-Data API. Not affiliated with Chess.com.",
  "keywords": [
    "chess.com",
    "chesscom",
    "chess",
    "chess-api",
    "api",
    "sdk",
    "typescript"
  ],
  "author": "dpianelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denispianelli/chesscom.git"
  },
  "homepage": "https://github.com/denispianelli/chesscom#readme",
  "bugs": {
    "url": "https://github.com/denispianelli/chesscom/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "attw": "attw --pack .",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "prepublishOnly": "npm run check && npm run build",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
